<?xml version="1.0" encoding="UTF-8" ?>
<odoo noupdate="1">
    <record id="ir_cron_membership_groups_categories_sync" model="ir.cron">
        <field name="name">Mail Groups based on Membership: end grace periods</field>
        <field name="user_id" ref="base.user_root" />
        <field name="model_id" ref="base.model_res_partner" />
        <field name="state">code</field>
        <field name="code">model._cron_membership_groups_end_grace()</field>
        <field name="interval_number" eval="24" />
        <field name="interval_type">hours</field>
        <field name="active" eval="True" />
    </record>
</odoo>
