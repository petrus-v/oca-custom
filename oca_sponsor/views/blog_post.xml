<odoo>
    <record id="blog_post_view_form_add" model="ir.ui.view">
        <field name="name">blog.post.view.form.add.oca_sponsor</field>
        <field name="model">blog.post</field>
        <field name="inherit_id" ref="website_blog.blog_post_view_form_add" />
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="author_id" />
            </field>
        </field>
    </record>

    <record id="view_blog_post_search" model="ir.ui.view">
        <field name="name">blog.post.search.oca_sponsor</field>
        <field name="model">blog.post</field>
        <field name="inherit_id" ref="website_blog.view_blog_post_search" />
        <field name="arch" type="xml">
            <field name="blog_id" position="after">
                <field name="author_id" />
            </field>
        </field>
    </record>
</odoo>
