<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_res_config_settings_membership_channel_sync" model="ir.ui.view">
        <field name="name">res.config.settings.membership.tag.sync</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <block id="user_default_rights" position="after">
                <block title="Membership Tag Sync" id="membership_tag_sync">
                    <setting
                        id="mcs_member_tag"
                        string="Member tag"
                        help="Partner tag that marks Members based on membership_state."
                    >
                        <field name="member_tag_id" options="{'no_create': True}" />
                    </setting>
                </block>
            </block>
        </field>
    </record>
</odoo>
