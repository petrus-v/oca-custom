<odoo>
    <!-- Integrator's contributor and member list -->
    <template id="contributor_index" name="OCA Contributors">
        <t t-call="website.layout">
            <t t-set="additional_title">OCA Contributors</t>
            <div id="wrap">
                <div id="oe_structure_contributor_header" class="oe_structure">
                    <section>
                        <div class="container">
                            <div class="row">
                                <div class="col-md-12">
                                    <h1 class="text-center">OCA Contributors
                                    </h1>
                                </div>
                            </div>
                        </div>
                    </section>
                </div>
                <div class="container">
                    <div class="row">
                        <div class="col-md-3 mb32" id="left_column">
                            <!-- Compute total for "All Countries" badge -->
                            <t t-set="all_countries_count" t-value="0" />
                            <t t-foreach="countries" t-as="c">
                                <t t-if="c.get('country_id')">
                                    <t
                                        t-set="all_countries_count"
                                        t-value="all_countries_count + (c.get('country_id_count') or 0)"
                                    />
                                </t>
                            </t>

                            <ul class="nav nav-pills flex-column mt16">
                                <!-- Header: Location + All Countries link -->
                                <li class="nav-header">
                                    <div
                                        class="d-flex align-items-baseline justify-content-between flex-wrap gap-2"
                                    >
                                        <h3 class="h4 mb-0">Location</h3>

                                        <a
                                            t-if="current_country_id"
                                            class="small text-muted text-decoration-none"
                                            t-attf-href="/integrators/#{ integrator }/contributors#{ search }"
                                        >
                                            All Countries
                                            <span
                                            class="badge rounded-pill text-bg-secondary ms-1"
                                        >
                                            <t t-esc="all_countries_count or '0'" />
                                        </span>
                                        </a>
                                    </div>
                                </li>

                                <!-- Country list -->
                                <t t-foreach="countries" t-as="country">
                                    <li
                                        t-if="country['country_id']"
                                        t-att-class="country['country_id'] and country['country_id'][0] == current_country_id and 'active' or None"
                                    >
                                        <a
                                            t-attf-href="/integrators/#{ integrator }/contributors#{ country['country_id'][0] and '/country/%s' % slug(country['country_id']) or '' }#{ search }"
                                        >
                                            <t t-esc="country['country_id'][1]" />

                                            <span
                                                class="badge float-end text-bg-secondary"
                                            >
                                                <t
                                                    t-esc="country['country_id_count'] or '0'"
                                                />
                                            </span>
                                        </a>
                                    </li>
                                </t>
                            </ul>
                        </div>
                        <div class="col-md-8" id="ref_content">
                            <div class='navbar'>
                                <t t-call="website.pager">
                                    <t t-set="classname">float-start</t>
                                </t>
                                <form action="" method="get" class="flex-grow-1">
                                    <div class="input-group" role="search">
                                        <input
                                            type="text"
                                            name="search"
                                            class="search-query form-control border-0 bg-light"
                                            placeholder="Search"
                                            t-att-value="post.get('search', '')"
                                        />
                                        <button
                                            type="submit"
                                            aria-label="Search"
                                            title="Search"
                                            class="oe_search_button btn btn-light"
                                        >
                                            <i class="oi oi-search" />
                                        </button>
                                    </div>
                                </form>
                            </div>
                            <div>
                                <t t-if="not contributors">
                                    <p>No result found.</p>
                                </t>
                                <t t-foreach="contributors" t-as="contributor">
                                    <div class="media">
                                        <a
                                            class="me-3 d-block"
                                            style="margin-top: 12px;"
                                            t-attf-href="/members/#{slug(contributor)}"
                                            t-field="contributor.image_1920"
                                            t-options='{"widget": "image", "class": "media-object", "max_width": 90}'
                                        />
                                        <div
                                            class="media-body"
                                            style="min-height:64px;"
                                        >
                                            <a
                                                class="media-heading"
                                                style="margin-top: 12px; display: inline-block;"
                                                t-attf-href="/members/#{slug(contributor)}"
                                            >
                                                <span
                                                    t-field="contributor.display_name"
                                                />
                                            </a>
                                            <t t-if="contributor.member_lines">
                                                <t
                                                    t-set="today_date"
                                                    t-value="datetime.date.today()"
                                                />
                                                <t
                                                    t-set="current_memberships"
                                                    t-value="contributor.member_lines.filtered(lambda membership: membership.state == 'paid' and membership.date_to &gt;= today_date and membership.date_from &lt;= today_date)"
                                                />
                                                <t
                                                    t-foreach="current_memberships"
                                                    t-as="membership"
                                                >
                                                    <img
                                                        class="img"
                                                        t-attf-src="/web/image/product.product/{{membership.membership_id.id}}/image_128"
                                                    />
                                                </t>
                                            </t>
                                            <div
                                                t-field="contributor.website_short_description"
                                            />
                                        </div>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
                <div id="oe_structure_contributor_footer" class="oe_structure" />
            </div>
        </t>
    </template>
    <!-- Contributor/Member page -->
    <template id="members" name="Members">
        <t t-call="website_membership.partner">
            <t t-set="left_column">
                <xpath expr="//div[hasclass('col-md-4')]/address" position="after">
                    <t t-if="partner.member_lines">
                        <div class="well">
                            <div class="row">
                                <t
                                    t-set="memberships_lines"
                                    t-value="partner.member_lines"
                                />
                                <h3
                                    class="text-center"
                                    style="margin-bottom: 24px; padding-bottom: 10px; border-bottom: solid 1px #ccc; margin: auto; width: 249px;"
                                >
                                    Membership Details
                                </h3>
                                <div
                                    style="margin-top: 12px; display: flex; flex-wrap: wrap"
                                >
                                    <div
                                        class="col-6 text-center mb8 border border-secondary"
                                        t-attf-style="left: #{ '25%' if len(memberships_lines)==1 else ''}"
                                        t-foreach="memberships_lines.sorted(key=lambda membership: membership.date, reverse=True)[:5]"
                                        t-as="membership"
                                    >
                                        <div style="border: solid 1px #ccc;">
                                            <img
                                                class="img"
                                                t-attf-src="/web/image/product.product/{{membership.membership_id.id}}/image_128"
                                            />
                                        </div>
                                        <span t-field="membership.membership_id.name" />
                                        <br />
                                        <span>(</span>
                                        <span
                                            t-field="membership.date"
                                            t-options='{"format": "yyyy"}'
                                        />
                                        <span>)</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </xpath>
            </t>
        </t>
    </template>
    <!-- Contributor/Member github url and company url -->
    <template
        id="contributor_github_url"
        inherit_id="website_partner.partner_detail"
        name="Contributor Github Link"
    >
        <xpath expr="//div[@t-field='partner.self']" position="after">
            <t t-if="partner and partner.github_url">
                <div>
                    <i class="fa fa-github" style="font-size:16px" />
                    <a t-att-href="partner.github_url">
                        <span t-field="partner.github_url" />
                    </a>
                </div>
            </t>
            <t
                t-if="partner.parent_id.is_integrator and partner.parent_id.website_published"
            >
                <div>
                    <i class="fa fa-building" style="font-size:16px" />
                    <a t-attf-href="/integrators/#{slug(partner.parent_id)}">
                        <span t-field="partner.parent_id.name" />
                    </a>
                </div>
            </t>
        </xpath>
    </template>
    <template
        id="contributor_modules_list"
        name="Contributor Modules Lists"
        inherit_id="website_partner.partner_detail"
    >
        <xpath expr="//div[hasclass('col-lg-9')]" position="inside">
            <t
                t-set="product_templates"
                t-value="partner.contributor_module_line_ids.sorted(key='date_pr_merged',reverse=True).mapped('product_template_id').filtered('website_published')"
            />
            <t t-if="product_templates">
                <div class="clearfix border_bottom">
                    <h3
                        id="modules_list"
                        style=" margin-bottom: 20px; border-bottom: solid 1px #ccc; padding-bottom: 20px;"
                    >
                        Latest Contributed Modules
                    </h3>
                </div>
                <div class="row">
                    <div>
                        <div class="border_bottom">
                            <div
                                class="col-sm-4"
                                t-foreach="product_templates"
                                t-as="module"
                                style="display: flex; align-items: center;"
                            >
                                <!-- if product has image then display it, otherwise display default module icon -->
                                <img
                                    t-attf-src="#{'/web/image/product.template/%s/image' %(module.id) if module.image_1920 else '/base/static/description/icon.png'}"
                                    style="margin-right: 10px; height: 70px"
                                />
                                <a t-attf-href="/shop/product/#{slug(module)}">
                                    <strong t-field="module.name" />
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </t>
        </xpath>
    </template>
</odoo>
