<odoo>
    <!-- Removes the access right check for summernote bundle -->
    <!-- Taken reference from website_forum.layout  -->
    <template
        id="integrator_editor_access"
        inherit_id="website.layout"
        name="Integrator portal layout"
    >
        <xpath expr="//div[@id='wrapwrap']" position="before">
            <t t-set="pageName" t-value="'website_forum'" />
        </xpath>
        <xpath expr="//div[@id='wrapwrap']" position="attributes">
            <attribute name="t-att-data-forum_id">forum and forum.id</attribute>
        </xpath>
    </template>
    <!-- Website portal integrator layout -->
    <template
        id="website_portal_integrator_details"
        inherit_id="portal.portal_my_details"
    >
        <xpath expr="//input[@name='redirect']" position="before">
            <t t-if="partner.is_integrator">
                <div
                    t-attf-class="form-group #{error.get('favourite_module_ids') and 'has-error' or ''} col-lg-6"
                >
                    <label class="control-label" for="favourite_module_ids">
                        Modules
                    </label>
                    <select
                        name="favourite_module_ids"
                        class="form-select module_js_select2"
                        multiple="multiple"
                    />
                </div>
                <div
                    t-attf-class="form-group #{error.get('github_organization') and 'has-error' or ''} col-lg-6"
                >
                    <label class="control-label" for="github_organization">
                        Github Login
                    </label>
                    <input
                        type="text"
                        name="github_organization"
                        class="form-control"
                        t-att-value="partner.github_organization"
                    />
                </div>
            </t>
        </xpath>
    </template>
</odoo>
