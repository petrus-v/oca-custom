<odoo>
    <record id="membership_category_tree_view" model="ir.ui.view">
        <field name="name">membership.category.oca_membership</field>
        <field name="model">membership.membership_category</field>
        <field
            name="inherit_id"
            ref="membership_extension.membership_category_tree_view"
        />

        <field name="arch" type="xml">
            <field name="name" position="before">
                <field name="sequence" widget="handle" />
            </field>

            <list position="inside">
                <field name="color" widget="color_picker" />
                <field name="implied_ids" widget="many2many_tags" />
            </list>
        </field>
    </record>
</odoo>
