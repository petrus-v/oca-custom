<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <template
        id="website_sale_products_moved_banner"
        inherit_id="website_sale.products"
        active="True"
        customize_show="True"
        name="Shop Moved Banner"
    >
        <xpath
            expr="//div[@id='oe_structure_website_sale_products_1']"
            position="before"
        >
            <t
                t-set="new_shop_url"
                t-value="request.env['ir.config_parameter'].sudo().get_param('website_oca_apps_new_shop.url', 'https://apps.odoo-community.org')"
            />
            <div
                class="alert alert-info d-flex flex-column flex-md-row justify-content-center align-items-center text-center gap-2"
                role="alert"
            >
                <span>The App Store has moved to a new location.</span>
                <a
                    class="btn btn-sm btn-primary"
                    t-att-href="new_shop_url"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Visit the new App store
                </a>
            </div>
        </xpath>
    </template>
</odoo>
